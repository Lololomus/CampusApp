# Core
APP_ENV=prod
LOG_LEVEL=INFO

# Database
POSTGRES_USER=campus
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_POSTGRES_PASSWORD
POSTGRES_DB=campusapp
POSTGRES_PORT=5432

# Runtime URLs are constructed by docker compose in production
REDIS_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_REDIS_PASSWORD

# Auth / Security
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
JWT_ALG=HS256
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=30
AUTH_MAX_SKEW_SECONDS=1800
AUTH_SESSION_BINDING_ENABLED=true
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# CORS
CORS_ORIGINS=https://app.example.com

# Analytics
ANALYTICS_SALT=CHANGE_ME_TO_A_LONG_RANDOM_ANALYTICS_SALT
ANALYTICS_NIGHTLY_ENABLED=true
ANALYTICS_NIGHTLY_HOUR_MSK=3
ANALYTICS_RAW_RETENTION_DAYS=180
ANALYTICS_AGG_RETENTION_DAYS=730

# Bot
BOT_TOKEN=123456789:CHANGE_ME_TO_A_REAL_BOT_TOKEN
BOT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_BOT_SECRET_AT_LEAST_32_CHARS
API_BASE_URL=http://backend:8000
NOTIFICATION_POLL_INTERVAL=20
FOLLOWUP_POLL_INTERVAL=30
MINIAPP_URL=https://app.example.com

# Webhook settings are unused in the production polling setup
WEBHOOK_HOST=
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8001

# Dev switches (must stay OFF in prod)
DEV_AUTH_ENABLED=false
DEV_TELEGRAM_IDS=
SQL_ECHO=false

# Backend workers
GUNICORN_WORKERS=4

# Market deal flow rollout
DEAL_FLOW_V2_ENABLED=false
MARKET_EXPIRY_WORKER_ENABLED=true
MARKET_EXPIRY_POLL_SECONDS=60
MARKET_LEAD_TTL_HOURS=168
MARKET_DEAL_SELECTED_TTL_HOURS=24
MARKET_SERVICE_IN_PROGRESS_TTL_HOURS=168
MARKET_DEAL_PROVIDER_CONFIRMED_TTL_HOURS=72
MARKET_REVIEW_STRICT_COMPLETED_AT=true
