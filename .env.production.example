# Core
APP_ENV=prod

# Database
POSTGRES_USER=campus
POSTGRES_PASSWORD=change_me
POSTGRES_DB=campusapp
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://campus:change_me@postgres:5432/campusapp

# Auth / Security
SECRET_KEY=change_me_long_random_secret
JWT_ALG=HS256
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=30
AUTH_MAX_SKEW_SECONDS=1800
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# CORS
CORS_ORIGINS=https://app.example.com

# Bot
BOT_TOKEN=change_me
BOT_SECRET=change_me
API_BASE_URL=http://backend:8000
NOTIFICATION_POLL_INTERVAL=20
FOLLOWUP_POLL_INTERVAL=30
MINIAPP_URL=https://app.example.com

# Webhook (not used in current polling implementation)
WEBHOOK_HOST=
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8001

# Dev switches (must stay OFF in prod)
DEV_AUTH_ENABLED=false
DEV_TELEGRAM_IDS=
SQL_ECHO=false
